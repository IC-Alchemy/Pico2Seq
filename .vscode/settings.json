{
    "files.associations": {
        "cmath": "cpp",
        "memory": "cpp",
        "semaphore": "cpp",
        "stop_token": "cpp"
    },
    "zencoder.mcpServers": {
        "playwright": {
            "command": "npx",
            "args": [
                "-y",
                "@playwright/mcp@latest",
                "--isolated",
                "--headless",
                "--browser",
                "firefox",
                "--user-agent",
                "\"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.6422.112 Safari/537.3\""
            ]
        },
        "context7": {
            "command": "npx",
            "args": [
                "-y",
                "@upstash/context7-mcp@latest"
            ]
        },
        "codacy": {
            "command": "npx",
            "args": [
                "-y",
                "@codacy/codacy-mcp"
            ],
            "env": {
                "CODACY_ACCOUNT_TOKEN": "<YOUR_TOKEN>"
            }
        }
    }
}